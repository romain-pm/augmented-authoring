{
  "name": "kfinder",
  "comment-for-name": "do not use kfind for package name otherwise it blocks the rendering of the ui",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint --ext js,jsx,ts,tsx,json,cjs,mjs .",
    "lint:fix": "yarn lint --fix"
  },
  "dependencies": {
    "@apollo/client": "^3.11.0",
    "@jahia/moonstone": "^2.17.5",
    "@jahia/ui-extender": "^1.2.0",
    "graphql": "^16.13.1",
    "i18next": "^20.6.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^11.2.2"
  },
  "devDependencies": {
    "@jahia/eslint-config": "^2.2.0",
    "@jahia/vite-federation-plugin": "^0.1.1",
    "@types/prop-types": "^15",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^8.57.1",
    "eslint-plugin-json": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "jahia": {
    "remotes": {
      "jahia": "javascript/apps/remoteEntry.js"
    },
    "apps": {
      "jahia": "configs/kfind.jsp"
    },
    "urlPatterns": {
      "jahia": "/administration/(?<siteKey>\\S*?)/settings/(?<settingName>\\S*)"
    }
  }
}
