{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "jsx": "preserve",
    "target": "esnext",
    "module": "preserve",
    "skipLibCheck": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noUncheckedSideEffectImports": true
  }
}
